generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectType {
  MANUAL
  AZURE_DEVOPS
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

model Project {
  id          String      @id @default(cuid())
  name        String
  description String?
  type        ProjectType @default(MANUAL)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  columns     KanbanColumn[]
  tasks       Task[]
  azureConfig AzureDevOpsConfig?
}

model KanbanColumn {
  id        String   @id @default(cuid())
  projectId String
  name      String
  order     Int
  isDone    Boolean  @default(false)
  createdAt DateTime @default(now())

  project        Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks          Task[]
  statusMappings TaskStatusMapping[]

  @@unique([projectId, order])
}

model Task {
  id          String       @id @default(cuid())
  projectId   String
  columnId    String
  title       String
  description String?
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  order       Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  column  KanbanColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([columnId])
}

model AzureDevOpsConfig {
  id              String   @id @default(cuid())
  projectId       String   @unique
  organization    String
  adoProject      String
  assignedToEmail String
  encryptedPat    String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project        Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  statusMappings TaskStatusMapping[]
}

model TaskStatusMapping {
  id         String @id @default(cuid())
  configId   String
  columnId   String
  azureState String

  config AzureDevOpsConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  column KanbanColumn      @relation(fields: [columnId], references: [id], onDelete: Cascade)

  @@unique([configId, azureState])
  @@unique([configId, columnId])
}
